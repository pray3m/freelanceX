# FreelanceX Frontend - Environment Variables Guide
# Copy this file to .env.local and fill in your actual values

# ============================================
# API Server
# ============================================
# Backend API URL (must match backend's PUBLIC_URL)
NEXT_PUBLIC_SERVER_URL=http://localhost:5001

# ============================================
# Stripe (Payment Processing)
# ============================================
# Stripe public key (safe to expose in frontend)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here

# ============================================
# Feature Flags
# ============================================
# Enable/disable features
# NEXT_PUBLIC_FEATURE_PAYMENTS=true
# NEXT_PUBLIC_FEATURE_MESSAGES=true
